{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Run summarize_notes.py",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/summarize_notes.py",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Run claude_cli.py",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/claude_cli.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "ANTHROPIC_API_KEY": "${env:ANTHROPIC_API_KEY}"
      }
    },
    {
      "name": "Launch Node Script",
      "type": "node",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    },
    {
      "name": "Attach to Chrome",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true
    }
  ]
}
