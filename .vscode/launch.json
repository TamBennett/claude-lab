{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Run summarize_notes.py",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/summarize_notes.py",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Run claude_cli.py",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/claude_cli.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "ANTHROPIC_API_KEY": "${env:ANTHROPIC_API_KEY}"
      }
    },
    {
      "name": "Launch Node Script",
      "type": "node",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    },
    {
      "name": "Attach to Chrome",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true
    },
    {
      "name": "FastAPI: backend",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--port", "8000"],
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": { "ANTHROPIC_API_KEY": "${env:ANTHROPIC_API_KEY}" }
    },
    {
      "name": "Vite: frontend",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "console": "integratedTerminal"
    },
    {
      "name": "Chrome: open app",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend"
    }
  ],
  "compounds": [
    {
      "name": "Full stack: FastAPI + Vite",
      "configurations": ["FastAPI: backend", "Vite: frontend", "Chrome: open app"],
      "stopAll": true
    }
  ]
}
